AFTER UPDATE OF status ON tickets
WHEN NEW.status = 'resolved'
BEGIN
    INSERT OR IGNORE INTO pending_feedback_requests(
        user_id, channel_id, ticket_id, source, created_at, expires_at
    )
    VALUES(
        NEW.user_id,
        NEW.channel_id,
        NEW.ticket_id,
        CASE
