       END) AS resolved_30d,
       MIN(m.created_at) AS first_seen_at,
       MAX(COALESCE(t.resolved_at, t.created_at, m.created_at)) AS last_ticket_activity_at
  FROM messages m
  LEFT JOIN tickets t ON t.ticket_id = m.ticket_id
 WHERE m.user_id = ?
]
