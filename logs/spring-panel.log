     WHERE f.ticket_id = m.ticket_id
     ORDER BY f.timestamp DESC, f.id DESC
     LIMIT 1
) AS rating,

       (
           SELECT sender
             FROM chat_history ch
            WHERE ch.ticket_id = t.ticket_id
            ORDER BY substr(ch.timestamp, 1, 19) DESC,
                     COALESCE(ch.tg_message_id, 0) DESC,
                     ch.id DESC
            LIMIT 1
       ) AS last_sender,
       (
