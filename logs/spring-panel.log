                             AND lower(op.sender) IN ('operator', 'support', 'admin', 'system', 'ai_agent')
                      ),
                      ''
                  )
           )
           ELSE 0
       END AS unread_count
  FROM tickets t
  LEFT JOIN messages m ON m.group_msg_id = (
