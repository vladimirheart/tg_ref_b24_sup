                             m3.group_msg_id DESC
                    LIMIT 1
               )
           )
       )
  ORDER BY substr(COALESCE(
               (
                   SELECT timestamp
                     FROM chat_history ch
                    WHERE ch.ticket_id = t.ticket_id
                    ORDER BY substr(ch.timestamp, 1, 19) DESC,
                             COALESCE(ch.tg_message_id, 0) DESC,
                             ch.id DESC
                    LIMIT 1
               ),
               COALESCE(m.created_at, t.created_at)
           ), 1, 19) DESC,
           t.ticket_id DESC
]
