         FROM chat_history ch
        WHERE ch.ticket_id = t.ticket_id
          AND lower(COALESCE(ch.sender, '')) IN ('operator', 'support', 'admin', 'system', 'ai_agent')
   )
 ORDER BY t.ticket_id DESC
]
