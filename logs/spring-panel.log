        UNION ALL
        SELECT COALESCE(t.assignee, t.creator, 'system') AS actor,
               COALESCE(th.at, t.last_activity_at, t.created_at, CURRENT_TIMESTAMP) AS event_at,
               'workflow' AS event_type,
               NULL AS action,
               NULL AS result,
               COALESCE(th.text, 'Обновление workflow') AS detail,
               th.id AS sort_id
          FROM task_links tl
