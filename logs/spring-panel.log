                      AND m3.user_id IS NOT NULL
                    ORDER BY substr(m3.created_at, 1, 19) DESC,
                             m3.group_msg_id DESC
                    LIMIT 1
               )
           )
       )
  ORDER BY substr(COALESCE(m.created_at, t.created_at), 1, 19) DESC,
           t.ticket_id DESC
]
