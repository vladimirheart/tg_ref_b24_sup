                WHERE ch.ticket_id = t.ticket_id
                  AND lower(ch.sender) NOT IN ('operator', 'support', 'admin', 'system', 'ai_agent')
                  AND ch.timestamp > COALESCE(
                      tr.last_read_at,
                      (
                          SELECT MAX(op.timestamp)
