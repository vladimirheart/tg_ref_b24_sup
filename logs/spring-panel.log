   AND (? IS NULL OR experiment_name = ?)
 GROUP BY COALESCE(experiment_cohort, 'unknown'), COALESCE(operator_segment, 'unknown')
 ORDER BY events DESC, experiment_cohort ASC, operator_segment ASC
]
