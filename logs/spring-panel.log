            LIMIT 1
       ) AS last_sender_time,
       (
           SELECT GROUP_CONCAT(tc.category, ', ')
             FROM ticket_categories tc
            WHERE tc.ticket_id = t.ticket_id
       ) AS categories,
       CASE
           WHEN tr.responsible IS NULL OR trim(tr.responsible) = '' OR lower(COALESCE(tr.responsible, '')) = lower(?) THEN (
               SELECT COUNT(*)
