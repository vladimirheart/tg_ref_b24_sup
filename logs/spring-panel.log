 GROUP BY m.ticket_id, COALESCE(t.status, 'pending')
 ORDER BY MAX(substr(COALESCE(m.created_at, t.created_at), 1, 19)) DESC,
          m.ticket_id DESC
 LIMIT 2 OFFSET ?
]
