      "expected_auto_reply_allowed": true,
      "expected_requires_operator": false,
      "expect_confirmed": true
    },
    {
      "id": "delivery_delay",
      "message": "Доставка по заказу #{order_id} из {business} в {location} опоздала, что делать?",
