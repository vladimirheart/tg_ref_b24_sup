{
  "dataset_version": "2026-04-16.offline-eval.v1",
  "variants_per_template": 30,
  "businesses": [
    "блинбери",
    "сушивесла",
    "пиццафабрика",
    "bb"
  ],
  "channels": [
    "telegram",
    "vk",
    "max",
    "web_form"
  ],
  "locations": [
    "центр",
    "юг",
    "север",
    "мега"
  ],
  "amounts": [
    "499",
    "799",
    "1290",
    "1590"
  ],
  "templates": [
    {
      "id": "order_status",
      "message": "Подскажите, где мой заказ #{order_id} по {business} в {channel} для точки {location}?",
