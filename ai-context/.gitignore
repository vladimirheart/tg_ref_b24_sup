# В git хранится читаемый markdown-контекст и versioned metadata.
content/*.html
content/*.tmp
content/*.tmp.*

# Python cache от baseline-скриптов не должен попадать в git.
__pycache__/
*.py[cod]

# Markdown-снимки контекста сохраняются.
!content/*.md
!content/.gitkeep

# Local-machine secrets всегда должны оставаться локальными.
parameters/local-machine/*
!parameters/local-machine/.gitignore
